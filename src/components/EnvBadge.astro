---
import {
  detectDbEnvironment,
  getSupabaseUrl,
  getStudioUrl,
  ENV_LABEL,
} from '../lib/db/environment';

interface Props {
  /** M9: 'inline' — statycznie w headerze obok ThemeToggle; 'floating' — róg ekranu (strony anon); 'compact' — kolorowy dot (mobile). */
  variant?: 'floating' | 'inline' | 'compact';
}

const { variant = 'floating' } = Astro.props;
const dbEnv = detectDbEnvironment();
const url = getSupabaseUrl();
const studioUrl = getStudioUrl();

const styles: Record<typeof dbEnv, string> = {
  local: 'bg-green-600 ring-green-300',
  prod: 'bg-red-600 ring-red-300 animate-pulse',
  unknown: 'bg-yellow-500 ring-yellow-300',
};

const COMPACT_LABEL: Record<typeof dbEnv, string> = { local: 'L', prod: 'P', unknown: '?' };

const placement =
  variant === 'inline'
    ? 'rounded-full px-2.5 py-1.5 text-xs font-semibold text-white'
    : variant === 'compact'
      ? 'inline-flex h-8 w-8 items-center justify-center rounded-full text-[10px] font-bold text-white'
      : 'fixed bottom-2 right-2 z-[9999] rounded-md px-3 py-1.5 text-xs font-bold text-white shadow-lg ring-2';
---

{
  studioUrl ? (
    <a
      href={studioUrl}
      target="_blank"
      rel="noopener noreferrer"
      class={`${placement} ${styles[dbEnv]} cursor-pointer transition-opacity hover:opacity-80`}
      data-testid="env-badge"
      data-env={dbEnv}
      title={`Supabase Studio: ${studioUrl}`}
    >
      {variant === 'compact' ? COMPACT_LABEL[dbEnv] : ENV_LABEL[dbEnv]}
    </a>
  ) : (
    <div
      class={`${placement} ${styles[dbEnv]}`}
      data-testid="env-badge"
      data-env={dbEnv}
      title={`Supabase: ${url || '(brak URL)'}`}
    >
      {variant === 'compact' ? COMPACT_LABEL[dbEnv] : ENV_LABEL[dbEnv]}
    </div>
  )
}
