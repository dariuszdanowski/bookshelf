---
import '../styles/global.css';
import MobileNav from '../components/MobileNav.tsx';
import UserMenu from '../components/UserMenu.tsx';
import ThemeToggle from '../components/ThemeToggle.tsx';
import EnvBadge from '../components/EnvBadge.astro';
import { detectDbEnvironment, ENV_LABEL } from '../lib/db/environment';

interface Props {
  title?: string;
}

const { title = 'BookShelf Catalog' } = Astro.props;
const user = Astro.locals.user;
const dbEnv = detectDbEnvironment();
const titleWithEnv = `[${ENV_LABEL[dbEnv]}] ${title}`;
const currentPath = Astro.url.pathname;

let displayName: string | null = null;
if (user) {
  const { data: profile } = await Astro.locals.supabase
    .from('profiles')
    .select('display_name')
    .eq('id', user.id)
    .single();
  displayName = profile?.display_name ?? null;
}

function navCls(href: string) {
  const active = currentPath === href || currentPath.startsWith(href + '/');
  return active
    ? 'font-semibold text-indigo-600 dark:text-indigo-400'
    : 'font-medium text-gray-700 hover:text-gray-900 dark:text-gray-300 dark:hover:text-gray-100';
}
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      (() => {
        try {
          // M17: trzeci stan 'system' — jawnie wybrany lub brak wpisu (default)
          // rozwiązuje się do prefers-color-scheme. html.dark = source of truth.
          const key = 'bookshelf:theme-mode';
          const stored = window.localStorage.getItem(key);
          const mode =
            stored === 'dark' || stored === 'light'
              ? stored
              : window.matchMedia('(prefers-color-scheme: dark)').matches
                ? 'dark'
                : 'light';
          document.documentElement.classList.toggle('dark', mode === 'dark');
          document.documentElement.setAttribute('data-theme', mode);
        } catch {
          document.documentElement.classList.remove('dark');
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
    <title>{titleWithEnv}</title>
  </head>
  <body>
    {/* S-38: header zawsze widoczny — Pomoc i logo dostępne też na ekranie logowania */}
    <header class="relative flex items-center gap-4 p-3 text-sm sm:p-4" data-testid="auth-header">
      {/* Logo — link do strony głównej, zawsze widoczny */}
      <a
        href="/library"
        class="text-sm font-bold text-gray-800 hover:text-indigo-600 dark:text-gray-100 dark:hover:text-indigo-400"
        data-testid="nav-home"
        aria-label="BookShelf — strona główna"
      >
        BookShelf
      </a>
      {/* S-28: hamburger < md; tylko dla zalogowanych */}
      {user && <MobileNav client:load email={user.email ?? ''} currentPath={currentPath} />}
      {
        user && (
          <nav class="hidden items-center gap-4 md:flex" aria-label="Nawigacja główna">
            <a
              href="/library"
              class={navCls('/library')}
              aria-current={currentPath.startsWith('/library') ? 'page' : undefined}
              data-testid="nav-library"
            >
              Biblioteka
            </a>
            <a
              href="/shelves"
              class={navCls('/shelves')}
              aria-current={
                currentPath === '/shelves' || currentPath.startsWith('/shelves/')
                  ? 'page'
                  : undefined
              }
              data-testid="nav-shelves"
            >
              Moje półki
            </a>
            <a
              href="/upload"
              class={navCls('/upload')}
              aria-current={currentPath.startsWith('/upload') ? 'page' : undefined}
              data-testid="nav-upload"
            >
              Skanuj półkę
            </a>
            <a
              href="/purchase"
              class={navCls('/purchase')}
              aria-current={currentPath.startsWith('/purchase') ? 'page' : undefined}
              data-testid="nav-add-purchase"
            >
              Dodaj zakup
            </a>
            {/* S-38: link „Moje konto" usunięty z nav — wejście przez UserMenu → „Edytuj profil" */}
            <span class="sr-only" data-testid="user-email">
              {user.email}
            </span>
            <UserMenu client:load email={user.email ?? ''} displayName={displayName} />
          </nav>
        )
      }
      {/* Prawa strona — zawsze widoczna (auth i non-auth) */}
      <div class="ml-auto flex flex-shrink-0 items-center gap-2">
        <ThemeToggle client:only="react" />
        {/* M9: badge środowiska */}
        <EnvBadge variant="inline" />
        {/* S-38: Pomoc — indigo pill dostępna na każdej stronie, w tym na logowaniu */}
        <a
          href="/help"
          class="inline-flex items-center gap-1.5 rounded-full bg-indigo-600 px-2.5 py-1.5 text-xs font-semibold text-white shadow-sm hover:bg-indigo-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 dark:bg-indigo-500 dark:hover:bg-indigo-400"
          aria-current={currentPath === '/help' ? 'page' : undefined}
          data-testid="nav-help"
        >
          <svg
            width="13"
            height="13"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
            <line x1="12" y1="17" x2="12.01" y2="17"></line>
          </svg>
          <span class="hidden sm:inline">Pomoc</span>
        </a>
      </div>
    </header>
    <slot />
  </body>
</html>
