---
import Layout from '../layouts/Layout.astro';

export const prerender = false;

// Middleware blokuje anonimów; dodatkowe sprawdzenie is_admin dla defense-in-depth.
const user = Astro.locals.user!;

const { data: profile } = await Astro.locals.supabase
  .from('profiles')
  .select('is_admin')
  .eq('id', user.id)
  .single();

if (!profile?.is_admin) {
  return Astro.redirect('/');
}
---

<Layout title="Panel administratora">
  <main class="mx-auto max-w-5xl p-4 sm:p-8">
    <h1 class="mb-6 text-3xl font-bold">Panel administratora</h1>
    <p class="text-gray-500 dark:text-gray-400">Wkrótce: lista użytkowników.</p>
  </main>
</Layout>
