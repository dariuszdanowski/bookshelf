---
export const prerender = false;

import Breadcrumb from '../../components/Breadcrumb.astro';
import Layout from '../../layouts/Layout.astro';
import DetectionReview from '../../components/DetectionReview.tsx';
import { parseUuidParam } from '../../lib/http/response';

// Protected path: middleware ensures locals.user is non-null (redirect to /login for anon).
if (!Astro.locals.user) {
  return Astro.redirect('/login');
}

const photoId = parseUuidParam(Astro.params.id);
if (!photoId) {
  return Astro.redirect('/shelves');
}

// S-37: deep-link z karty książki — ?detection=<uuid> fokusuje ramkę detekcji.
// Zniekształcony UUID → null (graceful: strona renderuje się bez fokusu).
const focusedDetectionId = parseUuidParam(Astro.url.searchParams.get('detection') ?? undefined);

// SSR fetch shelf info for breadcrumb and "Dodaj zdjęcie" button.
// Non-blocking: if photo/shelf missing, breadcrumb degrades gracefully.
let shelfId: string | null = null;
let shelfName: string | null = null;

const { data: photo } = await Astro.locals.supabase
  .from('photos')
  .select('shelf_id')
  .eq('id', photoId)
  .maybeSingle();

if (photo?.shelf_id) {
  shelfId = photo.shelf_id;
  const { data: shelf } = await Astro.locals.supabase
    .from('shelves')
    .select('name')
    .eq('id', shelfId)
    .maybeSingle();
  shelfName = shelf?.name ?? null;
}

const breadcrumbItems = [
  { label: 'Moje półki', href: '/shelves' },
  ...(shelfId && shelfName ? [{ label: shelfName, href: `/shelves/${shelfId}` }] : []),
  { label: 'Propozycje książek' },
];
---

<Layout title="Propozycje książek">
  <main class="mx-auto max-w-6xl p-8">
    <Breadcrumb items={breadcrumbItems} />

    <div class="mb-6 flex items-center justify-between">
      <h1 class="text-2xl font-bold">Propozycje książek</h1>
      {
        shelfId && (
          <a
            href={`/upload?shelf=${shelfId}`}
            class="inline-flex items-center rounded-md border border-transparent bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700"
          >
            + Dodaj zdjęcie
          </a>
        )
      }
    </div>

    <p class="mb-6 text-sm text-gray-600">
      Przejrzyj dopasowania. Zielone — wysoka pewność. Żółte — sprawdź przed akceptacją.
    </p>
    <DetectionReview client:load photoId={photoId} initialFocusedDetectionId={focusedDetectionId} />
  </main>
</Layout>
