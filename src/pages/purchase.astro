---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import AddPurchaseIsland from '../components/AddPurchaseIsland.tsx';

// Protected path: middleware przekierowuje anon na /login.
if (!Astro.locals.user) {
  return Astro.redirect('/login');
}
---

<Layout title="Dodaj zakup">
  <main class="mx-auto max-w-xl p-8">
    <div class="mb-4 text-sm text-gray-500">
      <a href="/shelves" class="text-blue-600 hover:text-blue-800">Moje półki</a>
      <span class="mx-1">&rsaquo;</span>
      <span>Dodaj zakup</span>
    </div>
    <h1 class="mb-2 text-3xl font-bold">Dodaj zakup</h1>
    <p class="mb-6 text-sm text-gray-600">
      Nowa książka trafi na półkę „Zakupione". Wpisz ręcznie albo zrób zdjęcie stosu.
    </p>
    <AddPurchaseIsland client:load />
  </main>
</Layout>
