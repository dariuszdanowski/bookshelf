---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import CatalogSearchIsland from '../components/CatalogSearchIsland.tsx';

// Protected path: middleware przekierowuje anon na /login.
if (!Astro.locals.user) {
  return Astro.redirect('/login');
}
---

<Layout title="Biblioteka">
  <main class="mx-auto max-w-5xl p-4 sm:p-8">
    <h1 class="mb-2 text-3xl font-bold">Biblioteka</h1>
    <p class="mb-6 text-sm text-gray-600">
      Przeszukaj cały katalog — po tytule, autorze, wydawnictwie; filtruj po kolorze grzbietu, półce
      i statusie przeczytania.
    </p>
    <CatalogSearchIsland client:load />
  </main>
</Layout>
