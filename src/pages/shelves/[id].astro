---
export const prerender = false;

import Breadcrumb from '../../components/Breadcrumb.astro';
import Layout from '../../layouts/Layout.astro';
import PhotoListIsland from '../../components/PhotoListIsland.tsx';
import ShelfBooksIsland from '../../components/ShelfBooksIsland.tsx';
import { parseUuidParam } from '../../lib/http/response';

if (!Astro.locals.user) {
  return Astro.redirect('/login');
}

const id = parseUuidParam(Astro.params.id);
if (!id) {
  return Astro.redirect('/shelves');
}

const { data: shelf, error: shelfError } = await Astro.locals.supabase
  .from('shelves')
  .select('name')
  .eq('id', id)
  .single();

if (shelfError || !shelf) {
  return Astro.redirect('/shelves');
}
---

<Layout title={`${shelf.name} — półka`}>
  <main class="mx-auto max-w-4xl p-8">
    <Breadcrumb items={[
      { label: 'Moje półki', href: '/shelves' },
      { label: shelf.name },
    ]} />

    <div class="mb-6 flex items-center justify-between">
      <h1 class="text-3xl font-bold">{shelf.name}</h1>
      <a
        href={`/upload?shelf=${id}`}
        class="inline-flex items-center rounded-md border border-transparent bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700"
      >
        + Dodaj zdjęcie
      </a>
    </div>

    <!-- Sekcja książek (S-05) — grid okładek z togglem przeczytania -->
    <section class="mb-10">
      <h2 class="mb-3 text-lg font-semibold text-gray-800">Książki na półce</h2>
      <ShelfBooksIsland client:load shelfId={id} />
    </section>

    <!-- Sekcja zdjęć -->
    <section>
      <h2 class="mb-3 text-lg font-semibold text-gray-800">Zdjęcia</h2>
      <PhotoListIsland client:load shelfId={id} shelfName={shelf.name} />
    </section>
  </main>
</Layout>
