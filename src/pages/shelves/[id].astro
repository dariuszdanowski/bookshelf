---
export const prerender = false;

import Breadcrumb from '../../components/Breadcrumb.astro';
import Layout from '../../layouts/Layout.astro';
import PhotoListIsland from '../../components/PhotoListIsland.tsx';
import ShelfBooksIsland from '../../components/ShelfBooksIsland.tsx';
import { parseUuidParam } from '../../lib/http/response';

if (!Astro.locals.user) {
  return Astro.redirect('/login');
}

const id = parseUuidParam(Astro.params.id);
if (!id) {
  return Astro.redirect('/shelves');
}

const { data: shelf, error: shelfError } = await Astro.locals.supabase
  .from('shelves')
  .select('name')
  .eq('id', id)
  .single();

if (shelfError || !shelf) {
  return Astro.redirect('/shelves');
}

// Agregaty półki: zdjęcia + suma wykrytych tytułów + potwierdzone książki
const [photosAgg, entriesAgg] = await Promise.all([
  Astro.locals.supabase
    .from('photos')
    .select('detected_count')
    .eq('shelf_id', id),
  Astro.locals.supabase
    .from('shelf_entries')
    .select('id')
    .eq('shelf_id', id)
    .eq('is_current', true),
]);

const photoCount = photosAgg.data?.length ?? 0;
const detectedCount = photosAgg.data?.reduce((s, p) => s + (p.detected_count ?? 0), 0) ?? 0;
const catalogedCount = entriesAgg.data?.length ?? 0;
---

<Layout title={`${shelf.name} — półka`}>
  <main class="mx-auto max-w-4xl p-8">
    <Breadcrumb items={[
      { label: 'Moje półki', href: '/shelves' },
      { label: shelf.name },
    ]} />

    <div class="mb-6 flex items-center justify-between">
      <h1 class="text-3xl font-bold">{shelf.name}</h1>
      <a
        href={`/upload?shelf=${id}`}
        class="inline-flex items-center rounded-md border border-transparent bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700"
      >
        + Dodaj zdjęcie
      </a>
    </div>

    <!-- Agregaty półki -->
    <div class="mb-8 grid grid-cols-3 gap-4 rounded-lg border border-gray-200 bg-gray-50 p-4" data-testid="shelf-stats">
      <div class="text-center">
        <p class="text-2xl font-bold text-gray-900" data-testid="shelf-stat-photos">{photoCount}</p>
        <p class="text-xs text-gray-500">zdjęć</p>
      </div>
      <div class="text-center">
        <p class="text-2xl font-bold text-gray-900" data-testid="shelf-stat-detected">{detectedCount}</p>
        <p class="text-xs text-gray-500">wykrytych tytułów</p>
      </div>
      <div class="text-center">
        <p class="text-2xl font-bold text-gray-900" data-testid="shelf-stat-cataloged">{catalogedCount}</p>
        <p class="text-xs text-gray-500">skatalogowanych</p>
      </div>
    </div>

    <!-- Sekcja książek (S-05) — grid okładek z togglem przeczytania -->
    <section class="mb-10">
      <h2 class="mb-3 text-lg font-semibold text-gray-800">Książki na półce</h2>
      <ShelfBooksIsland client:load shelfId={id} />
    </section>

    <!-- Sekcja zdjęć -->
    <section>
      <h2 class="mb-3 text-lg font-semibold text-gray-800">Zdjęcia</h2>
      <PhotoListIsland client:load shelfId={id} shelfName={shelf.name} />
    </section>
  </main>
</Layout>
