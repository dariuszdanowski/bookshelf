---
import Layout from '../layouts/Layout.astro';
---

<Layout title="BookShelf Catalog">
  <main class="flex min-h-screen items-center justify-center p-8">
    <div class="max-w-2xl space-y-4 text-center">
      <h1 class="text-4xl font-bold">BookShelf Catalog</h1>
      <p class="text-lg text-gray-600">
        Sfotografuj półkę → vision rozpoznaje tytuły → potwierdź wpisy.
      </p>
      <p class="text-sm text-gray-400">
        Bootstrap M1 — Astro 6 + React 19 + Tailwind 4 + Cloudflare.
      </p>
    </div>
  </main>
</Layout>
