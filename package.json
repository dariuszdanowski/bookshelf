{
  "name": "bookshelf",
  "type": "module",
  "version": "0.1.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "nodemon",
    "dev:once": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "generate-types": "wrangler types",
    "db:types": "npx supabase gen types typescript --linked --schema public > src/lib/db/database.types.ts",
    "db:start": "npx supabase start",
    "db:stop": "npx supabase stop",
    "db:status": "npx supabase status",
    "db:reset": "npx supabase db reset",
    "db:migrate": "npx supabase migration up",
    "db:push": "npx supabase db push",
    "env:local": "node scripts/switch-env.mjs local",
    "env:remote": "node scripts/switch-env.mjs remote",
    "env:status": "node scripts/switch-env.mjs status",
    "dev:local": "npm run env:local && npm run dev",
    "typecheck": "astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "benchmark:ocr": "node scripts/ocr-benchmark.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:mutation": "stryker run",
    "studio": "node scripts/open-studio.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@astrojs/cloudflare": "^13.7.0",
    "@astrojs/react": "^5.0.4",
    "@cf-wasm/photon": "^0.3.5",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.4.8",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.1",
    "tesseract.js": "^7.0.0",
    "wrangler": "^4.103.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "vite": "^7",
    "esbuild": ">=0.28.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^2.1.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.9",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
